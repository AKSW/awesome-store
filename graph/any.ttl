                                    ns1:destination "https://github.com/AKSW/airML" ;
                                    rdf:_1 "airML" ] ;
                            rdf:_2 " - No description available" ] ] ] ;
    rdf:_2 [ a ns1:Paragraph ;
            rdf:_1 "A list of projects from AKSW grouped by GitHub topics." ] ;
    rdf:_3 [ a ns1:Heading ;
            ns1:level "2"^^xsd:int ;
            rdf:_1 "Contents" ] ;
    rdf:_4 [ a ns1:BulletList ;
            rdf:_1 [ a ns1:ListItem ;
                    rdf:_1 [ a ns1:Paragraph ;
                            rdf:_1 [ a ns1:Link ;
                                    ns1:destination "#academic-data" ;
                                    rdf:_1 "academic-data" ] ] ] ;
            rdf:_2 [ a ns1:ListItem ;
                    rdf:_1 [ a ns1:Paragraph ;
                            rdf:_1 [ a ns1:Link ;
                                    ns1:destination "#accessibility" ;
                                    rdf:_1 "accessibility" ] ] ] ;
            rdf:_3 [ a ns1:ListItem ;
                    rdf:_1 [ a ns1:Paragraph ;
                            rdf:_1 [ a ns1:Link ;
                                    ns1:destination "#accessibilityservice" ;
                                    rdf:_1 "accessibilityservice" ] ] ] ;
            rdf:_4 [ a ns1:ListItem ;
                    rdf:_1 [ a ns1:Paragraph ;
                            rdf:_1 [ a ns1:Link ;
                                    ns1:destination "#ai-model-dependency-management" ;
                                    rdf:_1 "ai-model-dependency-management" ] ] ] ] ;
    rdf:_5 [ a ns1:Heading ;
            ns1:level "2"^^xsd:int ;
            rdf:_1 "academic-data" ] ;
    rdf:_6 [ a ns1:BulletList ;
            rdf:_1 [ a ns1:ListItem ;
