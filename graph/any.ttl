                                    ns1:destination "https://github.com/AKSW/leds-asp-f-ontologies" ;
                                    rdf:_1 "leds-asp-f-ontologies" ] ;
                            rdf:_2 " - This repository is part of ASP-F working group of the LEDS project. Here we develop/collect ontologies for later usage." ] ] ] ;
